{
  "name": "prisma-effect-schema-generator",
  "version": "0.1.0",
  "description": "Prisma generator that emits Effect Schema values for every model — drop-in validation for your database rows.",
  "keywords": [
    "prisma",
    "prisma-generator",
    "effect",
    "effect-schema",
    "schema",
    "validation",
    "orm",
    "typescript",
    "dmmf"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured'"
  },
  "dependencies": {
    "@prisma/generator-helper": "^7.0.0"
  },
  "peerDependencies": {
    "@prisma/generator-helper": "^7.0.0",
    "effect": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "effect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@prisma/generator-helper": "^7.8.0",
    "@types/node": "^22.10.0",
    "effect": "^3.21.0",
    "prisma": "^7.8.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
